---
import { siteConfig } from "../config";
const hasProjects = siteConfig.projects && siteConfig.projects.length > 0;

const [featured, ...rest] = siteConfig.projects ?? [];
---

{hasProjects && (
  <section id="projects" class="relative py-24 md:py-32 px-6 sm:px-10 md:px-16 lg:px-24">
    <div class="mx-auto max-w-7xl">
      <!-- Heading -->
      <div class="reveal mb-14 max-w-3xl">
        <p class="text-sm font-mono text-slate-500 tracking-widest uppercase">
          <span style="color: var(--accent);">03.</span> Things I've built
        </p>
        <h2 class="mt-3 text-3xl sm:text-4xl md:text-5xl font-bold section-title" style="font-family: var(--font-display);">
          Selected projects.
        </h2>
        <div class="mt-4 h-[3px] w-20 rounded-full accent-bar"></div>
      </div>

      <!-- Featured project -->
      {featured && (() => {
        const FTag = featured.link ? "a" : "div";
        const linkProps = featured.link ? { href: featured.link, target: "_blank", rel: "noopener noreferrer" } : {};
        return (
          <FTag
            {...linkProps}
            class={`reveal tilt group relative block overflow-hidden rounded-3xl border border-white/10 p-6 sm:p-10 md:p-12 mb-5 sm:mb-6 transition-all duration-300 ${featured.link ? "hover:-translate-y-1 hover:border-white/20" : ""}`}
            style="background: linear-gradient(135deg, rgba(51,65,85,0.08) 0%, rgba(71,85,105,0.06) 40%, rgba(100,116,139,0.05) 100%);"
          >
            <div class="pointer-events-none absolute -top-24 -right-24 w-[420px] h-[420px] rounded-full opacity-25 blur-3xl" style="background: radial-gradient(circle, #475569 0%, transparent 70%);"></div>

            <div class="relative grid grid-cols-1 lg:grid-cols-12 gap-6 lg:gap-10 items-center">
              <div class="lg:col-span-1">
                <div
                  class="text-5xl sm:text-6xl lg:text-7xl font-extrabold leading-none text-gradient"
                  style="font-family: var(--font-display);"
                >01</div>
              </div>
              <div class="lg:col-span-8">
                <div class="flex items-center gap-2 text-xs uppercase tracking-[0.22em] text-slate-400">
                  <span class="inline-block h-2 w-2 rounded-full" style="background: var(--accent);"></span>
                  Featured
                </div>
                <h3
                  class="mt-2 text-2xl sm:text-3xl md:text-4xl font-extrabold text-slate-100 leading-snug"
                  style="font-family: var(--font-display);"
                >
                  {featured.name}
                </h3>
                <p class="mt-4 text-base sm:text-lg text-slate-300 leading-relaxed">
                  {featured.description}
                </p>
                {featured.skills?.length > 0 && (
                  <div class="mt-5 flex flex-wrap gap-1.5">
                    {featured.skills.map((s) => (
                      <span class="inline-flex items-center rounded-md bg-white/[0.06] border border-white/10 px-2.5 py-1 text-xs font-mono text-slate-200">{s}</span>
                    ))}
                  </div>
                )}
              </div>
              <div class="lg:col-span-3 flex lg:justify-end">
                {featured.link && (
                  <span class="inline-flex items-center gap-2 rounded-full px-5 py-2.5 text-sm font-semibold text-white transition-transform duration-300 group-hover:-translate-y-0.5" style="background: linear-gradient(135deg, #0f172a, #334155 60%, #475569); box-shadow: 0 10px 30px -10px var(--accent-glow); color: #fff !important;">
                    View on GitHub
                    <svg class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                      <path stroke-linecap="round" stroke-linejoin="round" d="M17 8l4 4m0 0l-4 4m4-4H3" />
                    </svg>
                  </span>
                )}
              </div>
            </div>
          </FTag>
        );
      })()}

      <!-- Secondary projects grid -->
      {rest.length > 0 && (
        <div class="grid grid-cols-1 md:grid-cols-2 gap-5 sm:gap-6">
          {rest.map((project, index) => {
            const Tag = project.link ? "a" : "div";
            const linkProps = project.link ? { href: project.link, target: "_blank", rel: "noopener noreferrer" } : {};
            const num = String(index + 2).padStart(2, "0");
            return (
              <Tag
                {...linkProps}
                class={`reveal tilt group relative block rounded-2xl border border-white/10 bg-white/[0.03] p-6 sm:p-7 transition-all duration-300 ${project.link ? "hover:-translate-y-1 hover:border-white/20" : ""}`}
              >
                <!-- cursor glow -->
                <div
                  class="pointer-events-none absolute -inset-px rounded-2xl opacity-0 transition-opacity duration-300 group-hover:opacity-100"
                  style="background: radial-gradient(400px circle at var(--mx, 50%) var(--my, 50%), rgba(51, 65, 85, 0.10), transparent 40%);"
                ></div>

                <div class="relative flex h-full flex-col">
                  <div class="flex items-start justify-between gap-4">
                    <span
                      class="text-3xl font-extrabold leading-none"
                      style="font-family: var(--font-display); letter-spacing: -0.04em; background: linear-gradient(135deg, #0f172a, #475569, #94a3b8); -webkit-background-clip: text; background-clip: text; color: transparent;"
                    >{num}</span>
                    {project.link && (
                      <span class="inline-flex h-9 w-9 items-center justify-center rounded-full border border-white/10 text-slate-300 transition-all duration-300 group-hover:border-white/30 group-hover:text-white group-hover:-translate-y-0.5 group-hover:translate-x-0.5">
                        <svg class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                          <path stroke-linecap="round" stroke-linejoin="round" d="M7 17L17 7M17 7H7M17 7V17" />
                        </svg>
                      </span>
                    )}
                  </div>

                  <h3 class="mt-4 text-lg sm:text-xl font-bold text-slate-100 leading-snug">
                    {project.name}
                  </h3>

                  <p class="mt-3 text-sm text-slate-400 leading-relaxed flex-1">
                    {project.description}
                  </p>

                  {project.skills?.length > 0 && (
                    <div class="mt-5 flex flex-wrap gap-1.5">
                      {project.skills.map((skill) => (
                        <span class="inline-flex items-center rounded-md bg-white/[0.04] border border-white/10 px-2.5 py-1 text-xs font-mono text-slate-300">
                          {skill}
                        </span>
                      ))}
                    </div>
                  )}
                </div>
              </Tag>
            );
          })}
        </div>
      )}
    </div>

    <script is:inline>
      (function () {
        const cards = document.querySelectorAll('#projects .tilt');
        cards.forEach((card) => {
          card.addEventListener('mousemove', (e) => {
            const rect = card.getBoundingClientRect();
            card.style.setProperty('--mx', `${e.clientX - rect.left}px`);
            card.style.setProperty('--my', `${e.clientY - rect.top}px`);
          });
        });
      })();
    </script>
  </section>
)}
