---
import { siteConfig } from "../config";
const hasEducation = siteConfig.education && siteConfig.education.length > 0;

function parseGpa(achievements: string[]) {
  const line = achievements.find((a) => /^gpa/i.test(a));
  return line ? line.replace(/^gpa:\s*/i, "") : null;
}

/** e.g. "4.0/4.0" → "4/4"; "9.1/10" stays "9.1/10" */
function formatGpaDisplay(raw: string) {
  const parts = raw.split("/").map((p) => p.trim()).filter(Boolean);
  if (parts.length < 2) return raw.trim();
  const fmt = (s: string) => {
    const x = parseFloat(s);
    if (!Number.isFinite(x)) return s;
    return Number.isInteger(x) ? String(Math.trunc(x)) : String(x);
  };
  return `${fmt(parts[0])}/${fmt(parts[1])}`;
}

function parseCoursework(achievements: string[]) {
  const line = achievements.find((a) => /^coursework/i.test(a));
  if (!line) return [];
  return line
    .replace(/^coursework:\s*/i, "")
    .split(/,\s*/)
    .map((c) => c.trim())
    .filter(Boolean);
}

const ribbonGradients = [
  "linear-gradient(90deg, #0f172a 0%, #334155 50%, #64748b 100%)",
  "linear-gradient(90deg, #1e293b 0%, #475569 50%, #94a3b8 100%)",
];
---

{hasEducation && (
  <section id="education" class="relative py-24 md:py-32 px-6 sm:px-10 md:px-16 lg:px-24">
    <div class="mx-auto max-w-7xl">
      <!-- Heading -->
      <div class="reveal mb-14 max-w-3xl">
        <p class="text-sm font-mono text-slate-500 tracking-widest uppercase">
          <span style="color: var(--accent);">04.</span> Academics
        </p>
        <h2 class="mt-3 text-3xl sm:text-4xl md:text-5xl font-bold section-title" style="font-family: var(--font-display);">
          Education.
        </h2>
        <div class="mt-4 h-[3px] w-20 rounded-full accent-bar"></div>
      </div>

      <div class="grid grid-cols-1 md:grid-cols-2 gap-5 sm:gap-6">
        {siteConfig.education.map((edu, idx) => {
          const gpa = parseGpa(edu.achievements);
          const coursework = parseCoursework(edu.achievements);
          return (
            <article class="reveal group relative overflow-hidden rounded-3xl border border-white/10 bg-white/[0.03] transition-all duration-300 hover:border-white/20">
              <!-- Ribbon -->
              <div class="h-1.5 w-full" style={`background: ${ribbonGradients[idx % ribbonGradients.length]};`}></div>

              <!-- Glow -->
              <div class="pointer-events-none absolute -top-24 -right-24 w-[320px] h-[320px] rounded-full opacity-20 blur-3xl" style="background: radial-gradient(circle, #475569 0%, transparent 70%);"></div>

              <div class="relative p-6 sm:p-7">
                <div class="flex items-start justify-between gap-4">
                  {edu.logo && (
                    <div class="h-16 w-16 shrink-0 rounded-2xl bg-white flex items-center justify-center overflow-hidden shadow-md">
                      <img src={edu.logo} alt={`${edu.school} logo`} class="w-4/5 h-4/5 object-contain" />
                    </div>
                  )}
                  {gpa && (
                    <div class="relative">
                      <div
                        class="relative flex h-16 w-16 items-center justify-center rounded-full"
                        style="background: conic-gradient(from 180deg, #0f172a, #334155, #64748b, #0f172a); box-shadow: 0 10px 30px -10px var(--accent-glow);"
                      >
                        <div class="flex h-[54px] w-[54px] items-center justify-center rounded-full bg-[var(--bg-0)] text-center">
                          <div>
                            <div class="text-[11px] leading-none uppercase tracking-widest" style="color: var(--text-2);">GPA</div>
                            <div class="mt-0.5 text-sm font-extrabold tabular-nums leading-tight" style="color: var(--text-0);">{formatGpaDisplay(gpa)}</div>
                          </div>
                        </div>
                      </div>
                    </div>
                  )}
                </div>

                <h3 class="mt-5 text-xl sm:text-2xl font-extrabold text-slate-100 leading-tight" style="font-family: var(--font-display);">
                  {edu.degree}
                </h3>
                <p class="mt-1.5 text-sm sm:text-base text-gradient font-semibold">{edu.school}</p>

                <div class="mt-4 flex flex-wrap items-center gap-x-4 gap-y-1 text-xs font-mono text-slate-400">
                  <span class="inline-flex items-center gap-1.5">
                    <svg class="h-3.5 w-3.5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                      <path stroke-linecap="round" stroke-linejoin="round" d="M8 7V3m8 4V3m-9 8h10M5 21h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v12a2 2 0 002 2z" />
                    </svg>
                    {edu.dateRange}
                  </span>
                  {edu.location && (
                    <span class="inline-flex items-center gap-1.5">
                      <svg class="h-3.5 w-3.5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                        <path stroke-linecap="round" stroke-linejoin="round" d="M17.657 16.657L13.414 20.9a2 2 0 01-2.828 0l-4.244-4.243a8 8 0 1111.314 0z" />
                        <path stroke-linecap="round" stroke-linejoin="round" d="M15 11a3 3 0 11-6 0 3 3 0 016 0z" />
                      </svg>
                      {edu.location}
                    </span>
                  )}
                </div>

                {coursework.length > 0 && (
                  <div class="mt-6 pt-5 border-t border-white/5">
                    <p class="text-[11px] uppercase tracking-[0.22em] text-slate-500 mb-3">Coursework</p>
                    <div class="flex flex-wrap gap-1.5">
                      {coursework.map((c) => (
                        <span class="inline-flex items-center rounded-md bg-white/[0.04] border border-white/10 px-2.5 py-1 text-[11px] font-mono text-slate-300">
                          {c}
                        </span>
                      ))}
                    </div>
                  </div>
                )}
              </div>
            </article>
          );
        })}
      </div>
    </div>
  </section>
)}
