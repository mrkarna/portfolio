---
import { siteConfig } from "../config";

const hasProjects = siteConfig.projects && siteConfig.projects.length > 0;
const hasExperience = siteConfig.experience && siteConfig.experience.length > 0;
const hasEducation = siteConfig.education && siteConfig.education.length > 0;

const initials = siteConfig.name
  .split(" ")
  .map((w) => w[0])
  .join("")
  .slice(0, 2);

const navItems = [
  { id: "about", label: "About", show: true },
  { id: "experience", label: "Experience", show: hasExperience },
  { id: "projects", label: "Projects", show: hasProjects },
  { id: "education", label: "Education", show: hasEducation },
].filter((i) => i.show);
---

<header
  id="site-header"
  class="fixed top-0 left-0 right-0 z-50 transition-all duration-300"
>
  <div class="mx-auto max-w-6xl px-4 sm:px-6 py-3 sm:py-4">
    <nav
      id="nav-pill"
      class="flex items-center justify-between gap-4 rounded-full px-3 sm:px-4 py-2 transition-all duration-300"
    >
      <a href="#hero" class="flex items-center gap-2.5 pl-1 sm:pl-2">
        <span
          class="flex h-8 w-8 items-center justify-center rounded-lg text-xs font-bold text-white"
          style="background: linear-gradient(135deg, #0f172a 0%, #475569 100%); box-shadow: 0 6px 20px -8px var(--accent-glow);"
        >{initials}</span>
        <span class="hidden sm:inline text-sm font-semibold text-slate-200">{siteConfig.name.split(" ")[0]} {siteConfig.name.split(" ").slice(-1)[0][0]}.</span>
      </a>

      <ul class="hidden md:flex items-center gap-1">
        {navItems.map((item) => (
          <li>
            <a
              href={`#${item.id}`}
              data-nav={item.id}
              class="nav-link relative px-4 py-1.5 text-sm font-medium text-slate-300 transition-colors rounded-full hover:text-white"
            >
              {item.label}
            </a>
          </li>
        ))}
      </ul>

      <div class="flex items-center gap-2">
        {siteConfig.social?.github && (
          <a
            href={siteConfig.social.github}
            target="_blank"
            rel="noopener noreferrer"
            aria-label="GitHub"
            class="hidden sm:inline-flex h-9 w-9 items-center justify-center rounded-full text-slate-300 hover:text-white hover:bg-white/5 transition-colors"
          >
            <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="h-5 w-5">
              <path stroke="none" d="M0 0h24v24H0z" fill="none" />
              <path d="M9 19c-4.3 1.4 -4.3 -2.5 -6 -3m12 5v-3.5c0 -1 .1 -1.4 -.5 -2c2.8 -.3 5.5 -1.4 5.5 -6a4.6 4.6 0 0 0 -1.3 -3.2a4.2 4.2 0 0 0 -.1 -3.2s-1.1 -.3 -3.5 1.3a12.3 12.3 0 0 0 -6.2 0c-2.4 -1.6 -3.5 -1.3 -3.5 -1.3a4.2 4.2 0 0 0 -.1 3.2a4.6 4.6 0 0 0 -1.3 3.2c0 4.6 2.7 5.7 5.5 6c-.6 .6 -.6 1.2 -.5 2v3.5" />
            </svg>
          </a>
        )}
        {siteConfig.social?.email && (
          <a
            href={`mailto:${siteConfig.social.email}`}
            class="inline-flex items-center gap-1.5 rounded-full px-3.5 sm:px-4 py-1.5 text-xs sm:text-sm font-semibold text-white transition-all duration-300 hover:-translate-y-0.5"
            style="background: linear-gradient(135deg, #0f172a 0%, #334155 60%, #475569 100%); box-shadow: 0 6px 20px -8px var(--accent-glow);"
          >
            <span>Contact</span>
            <svg class="h-3.5 w-3.5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5">
              <path stroke-linecap="round" stroke-linejoin="round" d="M17 8l4 4m0 0l-4 4m4-4H3" />
            </svg>
          </a>
        )}
        <button
          id="mobile-menu-btn"
          class="md:hidden inline-flex h-9 w-9 items-center justify-center rounded-full text-slate-300 hover:text-white hover:bg-white/5"
          aria-label="Open menu"
        >
          <svg class="h-5 w-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
            <path stroke-linecap="round" stroke-linejoin="round" d="M4 6h16M4 12h16M4 18h16" />
          </svg>
        </button>
      </div>
    </nav>

    <!-- Mobile menu -->
    <div id="mobile-menu" class="md:hidden hidden mt-2 rounded-2xl glass overflow-hidden">
      <ul class="flex flex-col p-2">
        {navItems.map((item) => (
          <li>
            <a
              href={`#${item.id}`}
              class="block px-4 py-3 text-sm font-medium text-slate-200 hover:bg-white/5 rounded-xl"
            >
              {item.label}
            </a>
          </li>
        ))}
      </ul>
    </div>
  </div>
</header>

<script is:inline>
  (function () {
    const header = document.getElementById("site-header");
    const pill = document.getElementById("nav-pill");
    const onScroll = () => {
      if (window.scrollY > 20) {
        pill?.classList.add("glass", "shadow-lg");
      } else {
        pill?.classList.remove("glass", "shadow-lg");
      }
    };
    window.addEventListener("scroll", onScroll, { passive: true });
    onScroll();

    const btn = document.getElementById("mobile-menu-btn");
    const menu = document.getElementById("mobile-menu");
    btn?.addEventListener("click", () => menu?.classList.toggle("hidden"));
    menu?.querySelectorAll("a").forEach((a) =>
      a.addEventListener("click", () => menu.classList.add("hidden"))
    );
  })();
</script>

<style>
  :global(.nav-link.nav-active) {
    color: var(--text-0);
    background: rgba(51, 65, 85, 0.08);
  }
</style>
