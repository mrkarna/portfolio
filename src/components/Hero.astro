---
import { siteConfig } from "../config";

const currentRole = siteConfig.experience?.[0];
---

<section
  id="hero"
  class="relative isolate overflow-hidden min-h-screen flex items-center"
>
  <!-- Animated gradient blobs (subtle on light) -->
  <div class="absolute inset-0 -z-20 overflow-hidden">
    <div
      class="blob absolute -top-24 -left-24 w-[520px] h-[520px] rounded-full opacity-30"
      style="background: radial-gradient(circle, #334155 0%, transparent 70%);"
    ></div>
    <div
      class="blob absolute top-1/3 -right-24 w-[520px] h-[520px] rounded-full opacity-25"
      style="background: radial-gradient(circle, #475569 0%, transparent 70%); animation-delay: -6s;"
    ></div>
    <div
      class="blob absolute bottom-0 left-1/3 w-[440px] h-[440px] rounded-full opacity-20"
      style="background: radial-gradient(circle, #64748b 0%, transparent 70%); animation-delay: -12s;"
    ></div>
  </div>

  <!-- Subtle grid overlay -->
  <div
    class="absolute inset-0 -z-10 grid-bg [mask-image:radial-gradient(ellipse_at_center,black_30%,transparent_80%)]"
  ></div>

  <!-- Content -->
  <div class="relative mx-auto w-full max-w-7xl px-6 sm:px-10 md:px-16 lg:px-24 py-24">
    <div class="grid grid-cols-1 lg:grid-cols-12 gap-10 lg:gap-14 items-center">
      <div class="lg:col-span-7">
      <!-- Status badge -->
      <div class="animate-fade-in inline-flex items-center gap-2 rounded-full glass px-4 py-1.5 text-sm">
        <span class="relative flex h-2 w-2">
          <span class="absolute inline-flex h-full w-full rounded-full bg-emerald-400 opacity-75" style="animation: pulseGlow 2s ease-in-out infinite;"></span>
          <span class="relative inline-flex h-2 w-2 rounded-full bg-emerald-400"></span>
        </span>
        <span class="text-slate-300">
          {currentRole ? `${currentRole.title} @ ${currentRole.company}` : "Available for interesting problems"}
        </span>
      </div>

      <!-- Name -->
      <h1
        class="animate-fade-in animation-delay-400 mt-8 text-4xl sm:text-5xl md:text-6xl lg:text-7xl font-bold tracking-[-0.01em] leading-[1.04]"
        style="font-family: var(--font-display);"
      >
        <span class="text-slate-100">Hey. It's </span>
        <span class="text-gradient">{siteConfig.name.split(" ")[0]}</span>
        <span class="text-slate-100">.</span>
      </h1>

      <!-- Lead tagline -->
      <p
        class="animate-fade-in animation-delay-600 mt-7 text-lg sm:text-xl md:text-2xl text-slate-300 font-normal max-w-2xl leading-snug"
      >
        I design and ship
        <span class="text-slate-100 font-semibold">distributed systems</span>
        and
        <span class="text-slate-100 font-semibold">AI/ML infrastructure</span>
        — the kind where
        <span class="text-slate-100 font-semibold">milliseconds</span>,
        <span class="text-slate-100 font-semibold">uptime</span>, and
        <span class="text-slate-100 font-semibold">scale</span>
        actually matter.
      </p>

      <!-- Credential strip -->
      <p class="animate-fade-in animation-delay-600 mt-5 text-xs sm:text-sm font-mono text-slate-400 flex flex-wrap items-center gap-x-2 gap-y-1">
        <span class="text-slate-500">Now</span>
        <span class="text-slate-200">NVIDIA</span>
        <span class="text-slate-700">·</span>
        <span class="text-slate-500">Before</span>
        <span class="text-slate-300">Amazon</span>
      </p>

      <!-- CTAs -->
      <div class="animate-fade-in animation-delay-800 mt-10 flex flex-wrap items-center gap-4">
        <a
          href="#projects"
          class="group inline-flex items-center gap-2 rounded-full px-6 py-3 text-sm md:text-base font-semibold text-white transition-all duration-300 hover:-translate-y-0.5"
          style="background: linear-gradient(135deg, #0f172a 0%, #334155 60%, #475569 100%); box-shadow: 0 10px 30px -10px var(--accent-glow);"
        >
          View my work
          <svg class="h-4 w-4 transition-transform duration-300 group-hover:translate-x-0.5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
            <path stroke-linecap="round" stroke-linejoin="round" d="M17 8l4 4m0 0l-4 4m4-4H3" />
          </svg>
        </a>
        {siteConfig.social?.email && (
          <a
            href={`mailto:${siteConfig.social.email}`}
            class="group inline-flex items-center gap-2 rounded-full glass px-6 py-3 text-sm md:text-base font-semibold text-slate-100 transition-all duration-300 hover:-translate-y-0.5"
          >
            Get in touch
            <svg class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
              <path stroke-linecap="round" stroke-linejoin="round" d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z" />
            </svg>
          </a>
        )}
      </div>

      <!-- Social row -->
      <div class="animate-fade-in animation-delay-800 mt-10 flex items-center gap-5 text-slate-400">
        {siteConfig.social?.email && (
          <a href={`mailto:${siteConfig.social.email}`} aria-label="Email" class="transition-colors duration-300 hover:text-white">
            <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="h-6 w-6">
              <path stroke="none" d="M0 0h24v24H0z" fill="none" />
              <path d="M3 7a2 2 0 0 1 2 -2h14a2 2 0 0 1 2 2v10a2 2 0 0 1 -2 2h-14a2 2 0 0 1 -2 -2v-10z" />
              <path d="M3 7l9 6l9 -6" />
            </svg>
          </a>
        )}
        {siteConfig.social?.linkedin && (
          <a href={siteConfig.social.linkedin} target="_blank" rel="noopener noreferrer" aria-label="LinkedIn" class="transition-colors duration-300 hover:text-white">
            <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="h-6 w-6">
              <path stroke="none" d="M0 0h24v24H0z" fill="none" />
              <path d="M8 11v5" />
              <path d="M8 8v.01" />
              <path d="M12 16v-5" />
              <path d="M16 16v-3a2 2 0 1 0 -4 0" />
              <path d="M3 7a4 4 0 0 1 4 -4h10a4 4 0 0 1 4 4v10a4 4 0 0 1 -4 4h-10a4 4 0 0 1 -4 -4z" />
            </svg>
          </a>
        )}
        {siteConfig.social?.github && (
          <a href={siteConfig.social.github} target="_blank" rel="noopener noreferrer" aria-label="GitHub" class="transition-colors duration-300 hover:text-white">
            <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="h-6 w-6">
              <path stroke="none" d="M0 0h24v24H0z" fill="none" />
              <path d="M9 19c-4.3 1.4 -4.3 -2.5 -6 -3m12 5v-3.5c0 -1 .1 -1.4 -.5 -2c2.8 -.3 5.5 -1.4 5.5 -6a4.6 4.6 0 0 0 -1.3 -3.2a4.2 4.2 0 0 0 -.1 -3.2s-1.1 -.3 -3.5 1.3a12.3 12.3 0 0 0 -6.2 0c-2.4 -1.6 -3.5 -1.3 -3.5 -1.3a4.2 4.2 0 0 0 -.1 3.2a4.6 4.6 0 0 0 -1.3 3.2c0 4.6 2.7 5.7 5.5 6c-.6 .6 -.6 1.2 -.5 2v3.5" />
            </svg>
          </a>
        )}
      </div>
      </div>

      <!-- Right column: live terminal -->
      <div class="lg:col-span-5 lg:translate-x-12 xl:translate-x-20 animate-fade-in animation-delay-400">
        <div
          class="hero-term-shell relative rounded-2xl overflow-hidden"
          style="background: #2e3a4e; border: 1px solid rgba(148,163,184,0.28); box-shadow: 0 30px 80px -20px rgba(51,65,85,0.35);"
          aria-hidden="true"
        >
          <!-- Title bar -->
          <div
            class="flex items-center gap-2 px-4 py-3"
            style="background: rgba(255,255,255,0.05); border-bottom: 1px solid rgba(255,255,255,0.08);"
          >
            <span class="h-3 w-3 rounded-full" style="background: #ff5f56;"></span>
            <span class="h-3 w-3 rounded-full" style="background: #ffbd2e;"></span>
            <span class="h-3 w-3 rounded-full" style="background: #27c93f;"></span>
            <span class="ml-3 text-xs font-mono" style="color: #94a3b8;">manish@nvidia — zsh</span>
          </div>
          <pre
            id="hero-term"
            class="m-0 px-5 py-4 text-[13px] leading-6 font-mono whitespace-pre"
            style="color: #e2e8f0; min-height: 340px;"
          ></pre>
        </div>
      </div>
    </div>
  </div>

  <script is:inline>
    (function () {
      const el = document.getElementById("hero-term");
      if (!el) return;

      const G = '<span style="color:#64748b;">$</span>';
      const CMD = (s) => `<span style="color:#e2e8f0;">${s}</span>`;
      const OUT = (s) => `<span style="color:#4ade80;">${s}</span>`;
      const DIR = (s) => `<span style="color:#60a5fa;">${s}</span>`;
      const MUTED = (s) => `<span style="color:#94a3b8;">${s}</span>`;

      const seq = [
        { type: "cmd", text: "whoami" },
        { type: "out", html: OUT("manish") },
        { type: "blank" },
        { type: "cmd", text: "cat role.txt" },
        { type: "out", html: OUT("Software Engineer") },
        { type: "out", html: MUTED("@ NVIDIA · Santa Clara, CA") },
        { type: "blank" },
        { type: "cmd", text: "ls current-work/" },
        { type: "out", html: DIR("billing-platform/") },
        { type: "out", html: DIR("payments-service/") },
        { type: "out", html: DIR("fraud-detection/") },
        { type: "blank" },
        { type: "cmd", text: "echo $STACK" },
        { type: "out", html: MUTED("Go · Java · AWS · Kafka · k8s") },
      ];

      let buf = "";
      let cur = "";
      const CURSOR = '<span class="term-cursor">▋</span>';
      const render = () => { el.innerHTML = buf + cur + CURSOR; };
      const sleep = (ms) => new Promise((r) => setTimeout(r, ms));

      async function typeCmd(text) {
        cur = G + " ";
        render();
        await sleep(260);
        for (const ch of text) {
          cur += `<span style="color:#e2e8f0;">${ch}</span>`;
          render();
          await sleep(42 + Math.random() * 40);
        }
        buf += cur + "\n";
        cur = "";
        render();
        await sleep(220);
      }

      async function printOut(html) {
        buf += html + "\n";
        render();
        await sleep(110);
      }

      async function blank() {
        buf += "\n";
        render();
        await sleep(180);
      }

      async function runOnce(initialDelay) {
        buf = "";
        cur = "";
        render();
        await sleep(initialDelay);
        for (const step of seq) {
          if (step.type === "cmd") await typeCmd(step.text);
          else if (step.type === "out") await printOut(step.html);
          else if (step.type === "blank") await blank();
        }
        cur = G + " ";
        render();
        await sleep(2000);
      }

      (async () => {
        let first = true;
        while (true) {
          await runOnce(first ? 550 : 600);
          first = false;
        }
      })();
    })();
  </script>

  <style is:global>
    .term-cursor {
      display: inline-block;
      width: 0.55ch;
      color: #e2e8f0;
      animation: termblink 1s steps(1) infinite;
    }
    @keyframes termblink {
      50% { opacity: 0; }
    }
  </style>

  <!-- Scroll indicator -->
  <a
    href="#about"
    aria-label="Scroll to about"
    class="absolute bottom-8 left-1/2 -translate-x-1/2 text-slate-500 hover:text-slate-200 transition-colors"
  >
    <div class="flex flex-col items-center gap-2">
      <span class="text-xs uppercase tracking-[0.2em]">Scroll</span>
      <svg class="h-5 w-5 animate-bounce" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
        <path stroke-linecap="round" stroke-linejoin="round" d="M19 14l-7 7m0 0l-7-7m7 7V3" />
      </svg>
    </div>
  </a>
</section>
