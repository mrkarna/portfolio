---
import { siteConfig } from "../config";

const hasProjects = siteConfig.projects && siteConfig.projects.length > 0;
const hasExperience = siteConfig.experience && siteConfig.experience.length > 0;
const hasEducation = siteConfig.education && siteConfig.education.length > 0;
---

<footer class="relative mt-20 border-t border-white/5">
  <!-- CTA band -->
  <div class="relative mx-auto max-w-6xl px-6 lg:px-8 pt-20 pb-12">
    <div
      class="reveal relative overflow-hidden rounded-3xl p-10 sm:p-14 md:p-16 text-center glass"
    >
      <div
        class="absolute -top-24 left-1/2 -translate-x-1/2 w-[600px] h-[300px] rounded-full opacity-50 blur-3xl"
        style="background: radial-gradient(circle, #475569 0%, transparent 70%);"
      ></div>
      <p class="relative text-xs uppercase tracking-[0.25em] text-slate-400">Let's build</p>
      <h3 class="relative mt-4 text-3xl sm:text-4xl md:text-5xl font-extrabold text-slate-100" style="font-family: var(--font-display);">
        Have something <span class="text-gradient">ambitious</span> in mind?
      </h3>
      <p class="relative mt-4 text-base md:text-lg text-slate-300 max-w-xl mx-auto">
        I love working on challenging systems problems. Reach out and let's chat.
      </p>
      {siteConfig.social?.email && (
        <a
          href={`mailto:${siteConfig.social.email}`}
          class="relative mt-8 inline-flex items-center gap-2 rounded-full px-7 py-3 text-sm md:text-base font-semibold text-white transition-all duration-300 hover:-translate-y-0.5"
          style="background: linear-gradient(135deg, #0f172a 0%, #334155 60%, #475569 100%); box-shadow: 0 10px 30px -10px var(--accent-glow);"
        >
          Say hello
          <svg class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
            <path stroke-linecap="round" stroke-linejoin="round" d="M17 8l4 4m0 0l-4 4m4-4H3" />
          </svg>
        </a>
      )}
    </div>
  </div>

  <div class="mx-auto max-w-6xl px-6 lg:px-8 pb-10">
    <div class="flex flex-col md:flex-row md:items-center md:justify-between gap-6">
      <div>
        <h4 class="text-lg font-bold text-slate-100">{siteConfig.name}</h4>
        <p class="text-sm text-slate-400">{siteConfig.title}</p>
      </div>

      <nav class="flex flex-wrap gap-x-6 gap-y-2">
        <a href="#about" class="text-sm text-slate-400 hover:text-white transition-colors">About</a>
        {hasExperience && <a href="#experience" class="text-sm text-slate-400 hover:text-white transition-colors">Experience</a>}
        {hasProjects && <a href="#projects" class="text-sm text-slate-400 hover:text-white transition-colors">Projects</a>}
        {hasEducation && <a href="#education" class="text-sm text-slate-400 hover:text-white transition-colors">Education</a>}
      </nav>

      <div class="flex items-center gap-4 text-slate-400">
        {siteConfig.social?.email && (
          <a href={`mailto:${siteConfig.social.email}`} aria-label="Email" class="hover:text-white transition-colors">
            <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="h-5 w-5">
              <path stroke="none" d="M0 0h24v24H0z" fill="none" />
              <path d="M3 7a2 2 0 0 1 2 -2h14a2 2 0 0 1 2 2v10a2 2 0 0 1 -2 2h-14a2 2 0 0 1 -2 -2v-10z" />
              <path d="M3 7l9 6l9 -6" />
            </svg>
          </a>
        )}
        {siteConfig.social?.linkedin && (
          <a href={siteConfig.social.linkedin} target="_blank" rel="noopener noreferrer" aria-label="LinkedIn" class="hover:text-white transition-colors">
            <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="h-5 w-5">
              <path stroke="none" d="M0 0h24v24H0z" fill="none" />
              <path d="M8 11v5" />
              <path d="M8 8v.01" />
              <path d="M12 16v-5" />
              <path d="M16 16v-3a2 2 0 1 0 -4 0" />
              <path d="M3 7a4 4 0 0 1 4 -4h10a4 4 0 0 1 4 4v10a4 4 0 0 1 -4 4h-10a4 4 0 0 1 -4 -4z" />
            </svg>
          </a>
        )}
        {siteConfig.social?.github && (
          <a href={siteConfig.social.github} target="_blank" rel="noopener noreferrer" aria-label="GitHub" class="hover:text-white transition-colors">
            <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="h-5 w-5">
              <path stroke="none" d="M0 0h24v24H0z" fill="none" />
              <path d="M9 19c-4.3 1.4 -4.3 -2.5 -6 -3m12 5v-3.5c0 -1 .1 -1.4 -.5 -2c2.8 -.3 5.5 -1.4 5.5 -6a4.6 4.6 0 0 0 -1.3 -3.2a4.2 4.2 0 0 0 -.1 -3.2s-1.1 -.3 -3.5 1.3a12.3 12.3 0 0 0 -6.2 0c-2.4 -1.6 -3.5 -1.3 -3.5 -1.3a4.2 4.2 0 0 0 -.1 3.2a4.6 4.6 0 0 0 -1.3 3.2c0 4.6 2.7 5.7 5.5 6c-.6 .6 -.6 1.2 -.5 2v3.5" />
            </svg>
          </a>
        )}
      </div>
    </div>

    <div class="mt-8 pt-6 border-t border-white/5 text-xs text-slate-500 text-center">
      © {new Date().getFullYear()} {siteConfig.name}. Built with Astro + Tailwind.
    </div>
  </div>
</footer>
